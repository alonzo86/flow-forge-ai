{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "flow-forge-ai-ui (debug)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "flow_forge_ai_ui.app:app",
                "--host", "127.0.0.1",
                "--port", "8080",
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "Run flow-forge-ai example application",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "cwd": "${fileDirname}",
            "console": "integratedTerminal",
            "justMyCode": false
        },
    ]
}